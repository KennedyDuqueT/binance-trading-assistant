# BINANCE_MODE controla el comportamiento del asistente:
#   analysis_only (default) — solo lectura, sin ejecución
#   testnet                 — ejecución contra Binance Testnet (dinero falso)
#   mainnet                 — ejecución contra cuenta real (confirmación por orden)
BINANCE_MODE=analysis_only

# API keys de Binance Futures.
# Permissions: Reading ON. Spot/Margin/Futures Trading solo en testnet|mainnet.
# Withdrawals / Universal Transfer: NUNCA habilitar.
# IP whitelist: bind a la IP de casa (Binance > API Management > Edit restrictions).
BINANCE_API_KEY=
BINANCE_API_SECRET=
